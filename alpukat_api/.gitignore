# Python
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
env/

# Environment
.env

# Storage (jangan commit gambar user)
storage/uploads/*
!storage/uploads/.gitkeep

# Model TFLite: SENGAJA ikut di-commit (bukan di-ignore) karena file ini
# wajib ada di server saat deploy, dan ukurannya kecil (~2.8MB masing-masing)
# jadi aman untuk git biasa tanpa perlu Git LFS.
# models_tflite/*
# !models_tflite/.gitkeep

# Database dump & seeder (jangan commit data/kredensial)
*.sql

# Alembic
alembic/versions/*.py

# IDE
.vscode/
.idea/
*.swp