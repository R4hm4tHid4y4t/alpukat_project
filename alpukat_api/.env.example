# ===== APP =====
APP_NAME="Alpukat CNN API"
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
SECRET_KEY=ganti-dengan-random-string-panjang-minimal-32-karakter

# ===== DATABASE =====
DATABASE_URL=mysql+aiomysql://root:password@localhost:3306/alpukat_cnn_db

# ===== JWT =====
JWT_SECRET_KEY=ganti-dengan-jwt-secret-minimal-32-karakter
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ===== OTP =====
OTP_LENGTH=6
OTP_EXPIRE_MINUTES=10

# ===== EMAIL (Mailtrap untuk development) =====
MAIL_USERNAME=your_mailtrap_username
MAIL_PASSWORD=your_mailtrap_password
MAIL_FROM=noreply@alpukat.id
MAIL_PORT=587
MAIL_SERVER=smtp.mailtrap.io
MAIL_STARTTLS=True
MAIL_SSL_TLS=False

# ===== MODEL TFLITE =====
MODEL_VARIETAS_PATH=models_tflite/model_varietas.tflite
MODEL_KEMATANGAN_PATH=models_tflite/model_kematangan.tflite

# ===== STORAGE =====
STORAGE_PATH=storage/uploads
BASE_URL=http://localhost:8000
MAX_IMAGE_SIZE_MB=5

# ===== CONFIDENCE =====
CONFIDENCE_THRESHOLD=0.80
